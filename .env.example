# ─────────────────────────────────────────────────────────────
# J1-MSP-Toolkit — Environment Variables
# Copy to .env for reference (PowerShell scripts use these)
# ─────────────────────────────────────────────────────────────

# URL to the debloat script (override for custom/private forks)
# Leave empty to use the bundled local copy under debloat/
# DEBLOAT_SCRIPT_URL=https://raw.githubusercontent.com/OneByJorah/MSPEngine/main/debloat/MSP-Ultra-Debloat.ps1

# Temporary download path
# TEMP_PATH=%TEMP%\debloat.ps1

# PowerShell execution policy
# EXECUTION_POLICY=RemoteSigned
